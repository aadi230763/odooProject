# Base URL for the AssetFlow backend API.
# In dev this is proxied by Vite (see vite.config.ts), so the default works
# out of the box. Override for a deployed backend.
VITE_API_BASE_URL=/api

# Base URL for static assets (e.g. photos, QR codes).
# Set to the backend server URL in development (e.g. http://127.0.0.1:5000)
# or a CDN / empty string in production.
VITE_STATIC_URL=http://127.0.0.1:5000
