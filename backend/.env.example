# --- Flask ---
FLASK_ENV=development
SECRET_KEY=replace-with-a-long-random-string

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assetflow
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/assetflow_test

# --- Auth / JWT ---
JWT_SECRET=replace-with-a-different-long-random-string
JWT_EXPIRES_MINUTES=720

# --- CORS (comma-separated allowed frontend origins) ---
CORS_ORIGINS=http://localhost:5173
